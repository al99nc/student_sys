# Copy this file to .env and fill in your actual values

# ── Backend ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-min-32-random-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=20160

# AI / Groq
AI_API_KEY=your-groq-api-key
AI_API_KEYS=additional-keys-comma-separated
AI_MODEL=openai/gpt-oss-120b
CHAT_AI_MODEL=llama-3.1-8b-instant
CHAT_AI_API_KEY=your-groq-chat-api-key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/students_db

# Uploads
UPLOAD_DIR=uploads

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
BOT_TOKEN=your-bot-token-from-botfather
BOT_SECRET=generate-with-python-secrets.token_hex-32
BOT_USERNAME=your_bot_username
OWNER_ID=your-telegram-user-id
TELEGRAM_API_ID=your-api-id-from-my.telegram.org
TELEGRAM_API_HASH=your-api-hash-from-my.telegram.org
TELEGRAM_PHONE=+1234567890

# ── Frontend ──────────────────────────────────────────────────────────────────
MINI_APP_URL=https://your-domain.com/upload
BACKEND_URL=http://your-server-ip:8000
NEXT_PUBLIC_API_URL=http://your-server-ip:8000
