# Copy this file to .env and fill in your actual values

# ── Backend ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-min-32-random-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=20160

# AI / Groq
AI_API_KEY=your-groq-api-key
AI_API_KEYS=additional-keys-comma-separated
AI_MODEL=openai/gpt-oss-120b
CHAT_AI_MODEL=llama-3.1-8b-instant
CHAT_AI_API_KEY=your-groq-chat-api-key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/students_db

# Uploads
UPLOAD_DIR=uploads

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
BOT_TOKEN=your-bot-token-from-botfather
BOT_SECRET=generate-with-python-secrets.token_hex-32
BOT_USERNAME=your_bot_username
OWNER_ID=your-telegram-user-id
TELEGRAM_API_ID=your-api-id-from-my.telegram.org
TELEGRAM_API_HASH=your-api-hash-from-my.telegram.org
TELEGRAM_PHONE=+1234567890

# ── Pay-as-you-go credits (Stripe Checkout) ───────────────────────────────────
# Dashboard → Developers → API keys → Secret key
CHECKOUT_SECRET_KEY=sk_test_...
# Webhook endpoint signing secret (POST /billing/webhook on your API)
CHECKOUT_WEBHOOK_SECRET=whsec_...
# Where users return after pay/cancel (your Next.js origin)
APP_PUBLIC_URL=http://localhost:3000
CREDIT_PRICE_CENTS=100
CHECKOUT_CURRENCY=usd

# Tiering (credit_balance > 0 ⇒ premium: openai/gpt-oss-120b, higher monthly caps)
# FREE_PDF_UPLOADS_PER_MONTH=5
# PREMIUM_PDF_UPLOADS_PER_MONTH=20
# FREE_COACH_MESSAGES_PER_MONTH=30
# PREMIUM_COACH_MESSAGES_PER_MONTH=200
# FREE_CHAT_TIMEOUT_S=25
# PREMIUM_CHAT_TIMEOUT_S=120

# Credits spent per action (premium model when spend succeeds; 0 = no charge for that action)
# CREDIT_COST_MCQ_PROCESS=1
# CREDIT_COST_COACH_MESSAGE=1

# ── Wayl Payment Gateway (IQD — Iraqi Dinar) ─────────────────────────────────
# API key from your Wayl merchant dashboard (X-WAYL-AUTHENTICATION header)
WAYL_API_KEY=VNeHPjNGdHhlxsXVCYgO9g==:...
WAYL_API_BASE_URL=https://api.thewayl.com
# Price per credit in IQD (min link total is 1000 IQD; 5000 IQD default)
CREDIT_PRICE_IQD=5000

# ── Frontend ──────────────────────────────────────────────────────────────────
MINI_APP_URL=https://your-domain.com/upload
BACKEND_URL=http://your-server-ip:8000
NEXT_PUBLIC_API_URL=http://your-server-ip:8000
