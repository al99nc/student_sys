# Environment Variables for CortexQ
# Copy this file to .env and fill in your actual values

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=20160

# AI API Keys (Groq)
AI_API_KEY=your-groq-api-key-here
AI_API_KEYS=additional-keys-comma-separated
AI_MODEL=openai/gpt-oss-120b
CHAT_AI_MODEL=llama-3.1-8b-instant
CHAT_AI_API_KEY=your-groq-chat-api-key-here

# Database
DATABASE_URL=sqlite:///./students.db

# Uploads
UPLOAD_DIR=uploads

# Telegram Bot (for mini app)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here